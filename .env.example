# Environment Configuration Template
# Copy this file to .env.local, .env.stage, or .env.prod and fill in the values
# DO NOT commit actual .env files to git - they contain sensitive information

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/herplat?allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your_password_here

# Server Configuration
SERVER_PORT=9595

# Logging
LOG_FILE_PATH=/var/log/herplatform/application.log

# Secure Files
SECURE_FILES_PATH=/var/secure_files/files

# JWT Secret
JWT_SECRET=CardiRehabSecretKeyX12138yAn4

# Resend Email API (https://resend.com)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@cardirehab.com

# Frontend URL for password reset email links
FRONTEND_URL=https://www.cardirehab.com

# Mobile App Version Gate
# Set `MIN` to force-upgrade users below that version; set `LATEST` to soft-nudge
# users below it (dismissible). Bump `MIN` only for releases with breaking changes.
APP_ANDROID_LATEST=2.0.0
APP_ANDROID_MIN=2.0.0
APP_ANDROID_URL=https://play.google.com/store/apps/details?id=com.example.cardirehab_mobile
APP_IOS_LATEST=2.0.0
APP_IOS_MIN=2.0.0
APP_IOS_URL=https://apps.apple.com/app/cardirehab

# Push notifications (Firebase Cloud Messaging)
# Path to the Firebase Admin service-account JSON (downloaded from
# Firebase console → Project settings → Service accounts → Generate new private key).
# Place the file there and DO NOT commit it. If missing, push sending is just disabled.
FIREBASE_ENABLED=true
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# Board-of-Directors admin seed (manages the External Trusted Resources directory)
# On startup, DataSeeder always ensures the role rows exist. It creates the single
# ADMIN login ONLY when both EMAIL and PASSWORD below are set — leave them blank to skip.
# Set these, restart the service once to create the account, then you may clear PASSWORD.
ADMIN_SEED_ENABLED=true
ADMIN_SEED_USERNAME=boardadmin
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_PHONE=0000000000
